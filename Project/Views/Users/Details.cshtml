@model RaceReader.Models.ApplicationUser
@{
    ViewData["Title"] = "User Details";
}

<div class="mb-8">
    <a asp-action="Index" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors flex items-center gap-2 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Users
    </a>
    <h1 class="font-display font-black text-4xl text-white italic tracking-tight uppercase">User Details</h1>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 max-w-2xl shadow-2xl">
    <div class="space-y-6">
        <div>
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">ID</h3>
            <p class="text-gray-300 font-mono text-sm bg-gray-800 p-3 rounded-lg">@Model.Id</p>
        </div>
        <div>
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Email</h3>
            <p class="text-white font-medium text-lg">@Model.Email</p>
        </div>

        <div>
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Status</h3>
            @if (Model.EmailConfirmed)
            {
                <span class="inline-block px-3 py-1 bg-green-500/10 text-green-400 font-medium text-sm rounded border border-green-500/20">Email Confirmed</span>
            }
            else
            {
                <span class="inline-block px-3 py-1 bg-yellow-500/10 text-yellow-400 font-medium text-sm rounded border border-yellow-500/20">Email Pending</span>
            }
        </div>

        <div>
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Token Balance</h3>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-red/10 border border-brand-red/20 rounded-lg">
                <span class="text-brand-red font-black text-xl">@Model.TokenBalance</span>
                <span class="text-brand-red/80 text-sm font-semibold uppercase">Tokens</span>
            </div>
        </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-800 flex gap-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="px-6 py-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg transition-colors border border-gray-700">
            Edit User
        </a>
    </div>
</div>
