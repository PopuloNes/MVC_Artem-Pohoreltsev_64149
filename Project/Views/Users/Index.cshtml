@model IEnumerable<RaceReader.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="font-display font-black text-4xl text-white italic tracking-tight uppercase mb-2">User Management</h1>
        <p class="text-gray-400">Manage registered users and their token balances.</p>
    </div>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden shadow-2xl">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-800/50 border-b border-gray-700">
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Email</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Tokens</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Status</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                @foreach (var item in Model) {
                <tr class="hover:bg-gray-800/30 transition-colors group">
                    <td class="p-4">
                        <div class="font-medium text-white">@item.Email</div>
                    </td>
                    <td class="p-4 text-center">
                        <span class="px-2 py-1 bg-brand-red/10 text-brand-red font-bold text-sm rounded border border-brand-red/20">
                            @item.TokenBalance
                        </span>
                    </td>
                    <td class="p-4 text-center">
                        @if (item.EmailConfirmed)
                        {
                            <span class="px-2 py-1 bg-green-500/10 text-green-400 font-medium text-xs rounded border border-green-500/20">Confirmed</span>
                        }
                        else
                        {
                            <span class="px-2 py-1 bg-yellow-500/10 text-yellow-400 font-medium text-xs rounded border border-yellow-500/20">Pending</span>
                        }
                    </td>
                    <td class="p-4 text-right">
                        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-lg transition-colors" title="Edit">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-lg transition-colors" title="Details">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="p-2 text-red-500 hover:text-white hover:bg-red-600 rounded-lg transition-colors" title="Delete">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
