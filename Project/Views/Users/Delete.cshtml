@model RaceReader.Models.ApplicationUser
@{
    ViewData["Title"] = "Delete User";
}

<div class="mb-8">
    <a asp-action="Index" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors flex items-center gap-2 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Users
    </a>
    <h1 class="font-display font-black text-4xl text-white italic tracking-tight uppercase">Delete User</h1>
</div>

<div class="bg-gray-900 border border-brand-red/50 rounded-2xl p-8 max-w-2xl shadow-2xl relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-2 bg-brand-red"></div>
    <div class="flex items-center gap-4 mb-6">
        <div class="p-3 bg-brand-red/10 text-brand-red rounded-full">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <div>
            <h2 class="text-xl font-bold text-white">Are you absolutely sure?</h2>
            <p class="text-gray-400 text-sm">This action cannot be undone. This will permanently delete the user account, their reading history, library, and active tokens.</p>
        </div>
    </div>

    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 mb-8">
        <div class="mb-4">
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1">Email</span>
            <span class="text-white font-medium">@Model.Email</span>
        </div>
        <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1">Token Balance</span>
            <span class="text-brand-red font-black">@Model.TokenBalance Tokens</span>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="flex gap-4">
            <button type="submit" class="px-6 py-2 bg-brand-red hover:bg-red-700 text-white font-semibold rounded-lg transition-all shadow-lg shadow-brand-red/20">
                Yes, Delete User
            </button>
            <a asp-action="Index" class="px-6 py-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg transition-colors border border-gray-700">
                Cancel
            </a>
        </div>
    </form>
</div>
