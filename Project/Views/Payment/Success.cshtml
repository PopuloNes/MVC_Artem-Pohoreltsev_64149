@{
    ViewData["Title"] = "Payment Successful";
}

<div class="max-w-md mx-auto text-center mt-20 bg-gray-900 border border-brand-red rounded-3xl p-10 shadow-2xl shadow-brand-red/10">
    <div class="w-20 h-20 bg-brand-red/20 rounded-full flex items-center justify-center mx-auto mb-6 border border-brand-red">
        <svg class="w-10 h-10 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
    </div>
    
    <h1 class="font-display font-black text-3xl text-white mb-4 uppercase">Refueled!</h1>
    <p class="text-gray-400 mb-8">Your tokens have been successfully added to your account. You are ready to get back on track.</p>
    
    <a asp-controller="Home" asp-action="Index" class="inline-block w-full py-3 px-6 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-red/30 uppercase tracking-wide">
        Back to Catalog
    </a>
</div>
