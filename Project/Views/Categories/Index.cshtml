@model IEnumerable<RaceReader.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="max-w-6xl mx-auto py-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-black text-white italic uppercase tracking-wider">MANAGE GENRES</h1>
        <a asp-action="Create" class="px-6 py-2 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-colors shadow-lg shadow-brand-red/20 uppercase tracking-wide text-sm">Add New Genre</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden shadow-xl">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-800/50 text-gray-400 uppercase text-xs font-bold tracking-wider">
                <tr>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                @foreach (var item in Model) {
                <tr class="hover:bg-gray-800/30 transition-colors">
                    <td class="px-6 py-4 font-medium text-white">@item.Name</td>
                    <td class="px-6 py-4 font-medium space-x-4">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-gray-400 hover:text-white transition-colors">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-brand-red hover:text-red-400 transition-colors">Delete</a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
