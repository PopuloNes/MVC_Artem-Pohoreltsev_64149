@model RaceReader.Models.Category
@{
    ViewData["Title"] = "Add Genre";
}

<div class="max-w-4xl mx-auto py-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-black text-white italic uppercase tracking-wider">ADD NEW GENRE</h1>
        <a asp-action="Index" class="text-gray-400 hover:text-white transition-colors">Back to List</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-xl">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-brand-red mb-6 text-sm bg-red-900/20 p-4 rounded-lg border border-red-900/50"></div>
            
            <div class="mb-8">
                <label asp-for="Name" class="block text-sm font-bold text-gray-400 mb-2 uppercase tracking-wide">Genre Name</label>
                <input asp-for="Name" class="w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors" placeholder="e.g. Engineering" required />
                <span asp-validation-for="Name" class="text-brand-red text-xs mt-1 block"></span>
            </div>

            <div class="flex justify-end pt-4 border-t border-gray-800">
                <button type="submit" class="px-8 py-3 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-colors shadow-lg shadow-brand-red/20 uppercase tracking-wide">
                    Create Genre
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
