@model RaceReader.Controllers.LibraryViewModel
@{
    ViewData["Title"] = "My Library";
}

<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="font-display font-black text-3xl text-white uppercase tracking-tight">Driver <span class="text-brand-red">Dashboard</span></h1>
        <p class="text-gray-400">Manage your reading lists and view transaction history.</p>
    </div>
    <div class="bg-gray-900 border border-brand-red p-4 rounded-xl flex items-center gap-4 shadow-lg shadow-brand-red/10">
        <div class="w-12 h-12 bg-brand-red/20 rounded-full flex items-center justify-center border border-brand-red/50">
            <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div>
            <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Available Tokens</p>
            <p class="text-2xl font-black text-white leading-none">@Model.TokenBalance</p>
        </div>
        <a href="/Home/Pricing" class="ml-4 px-4 py-2 bg-brand-red hover:bg-red-700 text-white text-sm font-bold rounded-lg transition-colors">Top Up</a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
        <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden">
            <div class="p-6 border-b border-gray-800">
                <h3 class="font-display font-bold text-xl text-white">My Books</h3>
            </div>
            <div class="p-6">
                @if (!Model.LibraryItems.Any())
                {
                    <p class="text-gray-500 italic">Your library is empty. Start exploring the catalog!</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var item in Model.LibraryItems)
                        {
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-4 bg-gray-800/50 rounded-xl border border-gray-800 hover:border-gray-700 transition-colors">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-16 bg-gray-800 flex-shrink-0 rounded overflow-hidden">
                                        @if(!string.IsNullOrEmpty(item.Book?.CoverImagePath))
                                        {
                                            <img src="@item.Book.CoverImagePath" class="w-full h-full object-cover" />
                                        }
                                    </div>
                                    <div>
                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.BookId" class="font-bold text-white hover:text-brand-red transition-colors block mb-1">@(item.Book?.Title ?? "Unknown Book")</a>
                                        <span class="text-xs text-gray-500 uppercase font-bold tracking-wider">Status: <span class="text-gray-300">@item.Status</span></span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <form asp-action="UpdateStatus" method="post" class="m-0 flex items-center gap-2">
                                        <input type="hidden" name="bookId" value="@item.BookId" />
                                        <select name="status" class="bg-gray-900 border border-gray-700 text-white text-xs rounded-lg focus:ring-brand-red focus:border-brand-red block p-2 transition-colors outline-none" onchange="this.form.submit()">
                                            <option value="Planned" selected="@(item.Status == "Planned")">Planned</option>
                                            <option value="Reading" selected="@(item.Status == "Reading")">Reading</option>
                                            <option value="Completed" selected="@(item.Status == "Completed")">Completed</option>
                                        </select>
                                    </form>
                                    <a asp-controller="Reader" asp-action="Read" asp-route-id="@item.BookId" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white text-xs font-bold rounded-lg transition-colors whitespace-nowrap">
                                        Continue
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden">
            <div class="p-6 border-b border-gray-800">
                <h3 class="font-display font-bold text-xl text-white">Reading History & Stats</h3>
            </div>
            <div class="p-6">
                @if (!Model.ReadingSessions.Any())
                {
                    <p class="text-gray-500 italic">No reading data available yet.</p>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm text-gray-400">
                            <thead class="text-xs text-gray-500 uppercase bg-gray-800/50 border-b border-gray-800">
                                <tr>
                                    <th scope="col" class="px-4 py-3 font-bold">Book</th>
                                    <th scope="col" class="px-4 py-3 font-bold">Last Page</th>
                                    <th scope="col" class="px-4 py-3 font-bold">Time Spent</th>
                                    <th scope="col" class="px-4 py-3 font-bold">Tokens Used</th>
                                    <th scope="col" class="px-4 py-3 font-bold">Last Read</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in Model.ReadingSessions.OrderByDescending(s => s.LastReadAt))
                                {
                                    <tr class="border-b border-gray-800 hover:bg-gray-800/30 transition-colors">
                                        <td class="px-4 py-3 font-medium text-gray-300">@(session.Book?.Title ?? "Unknown Book")</td>
                                        <td class="px-4 py-3">@session.LastPageRead</td>
                                        <td class="px-4 py-3">@session.TotalMinutesSpent mins</td>
                                        <td class="px-4 py-3 text-brand-red font-bold">@session.TotalTokensSpent</td>
                                        <td class="px-4 py-3">@session.LastReadAt.ToString("MMM dd, yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="space-y-8">
        <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden">
            <div class="p-6 border-b border-gray-800">
                <h3 class="font-display font-bold text-xl text-white">Purchase History</h3>
            </div>
            <div class="p-6">
                @if (!Model.Transactions.Any())
                {
                    <p class="text-gray-500 italic text-sm">No token purchases yet.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var tx in Model.Transactions)
                        {
                            <div class="flex items-center justify-between border-b border-gray-800 pb-4 last:border-0 last:pb-0">
                                <div>
                                    <span class="block text-white font-bold text-sm mb-1">+@tx.TokensAdded Tokens</span>
                                    <span class="block text-xs text-gray-500">@tx.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="text-right">
                                    <span class="block text-brand-red font-bold text-sm mb-1">$@tx.Amount</span>
                                    <span class="block text-xs text-green-500 uppercase tracking-wider">@tx.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
