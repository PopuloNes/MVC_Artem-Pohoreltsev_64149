@model RaceReader.Models.Book
@{
    ViewData["Title"] = Model.Title;
    var avgRating = Model.Ratings.Any() ? Math.Round(Model.Ratings.Average(r => r.Score), 1) : 0.0;
}

<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="inline-flex items-center text-sm font-medium text-gray-400 hover:text-white transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Catalog
    </a>
</div>

<div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden shadow-2xl mb-12">
    <div class="flex flex-col md:flex-row">
        <div class="w-full md:w-1/3 lg:w-1/4 bg-gray-800 flex-shrink-0 relative">
            @if (!string.IsNullOrEmpty(Model.CoverImagePath))
            {
                <img src="@Model.CoverImagePath" alt="@Model.Title" class="w-full h-full object-cover aspect-[2/3] md:aspect-auto md:h-full" />
            }
            else
            {
                <div class="w-full aspect-[2/3] md:h-full flex items-center justify-center text-gray-600 font-display italic text-2xl uppercase">No Cover</div>
            }
        </div>
        <div class="p-8 md:p-12 flex-grow flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
                <span class="px-3 py-1 bg-gray-800 text-gray-300 text-xs font-bold rounded uppercase tracking-wider">
                    @(Model.Category?.Name ?? "N/A")
                </span>
            </div>
            <h1 class="font-display font-black text-4xl text-white mb-2 leading-tight">@Model.Title</h1>
            <p class="text-xl text-gray-400 mb-6 font-medium">@Model.Author</p>
            <div class="flex items-center gap-2 mb-8">
                <div class="flex text-yellow-500">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(avgRating))
                        {
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 text-gray-700" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        }
                    }
                </div>
                <span class="text-gray-400 font-medium">@avgRating (@Model.Ratings.Count reviews)</span>
            </div>
            <div class="prose prose-invert max-w-none mb-10 text-gray-300">
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)</p>
            </div>
            <div class="mt-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Reader" asp-action="Read" asp-route-id="@Model.Id" class="inline-flex items-center justify-center px-8 py-4 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-red/30 text-lg uppercase tracking-wide gap-3 w-full sm:w-auto">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        Start Reading
                    </a>
                    <p class="text-xs text-gray-500 mt-4 text-center sm:text-left">Tokens will be deducted per minute of reading.</p>
                }
                else
                {
                    <a href="/Identity/Account/Login" class="inline-flex items-center justify-center px-8 py-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition-all border border-gray-700 text-lg uppercase tracking-wide gap-3 w-full sm:w-auto">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        Sign in to Read
                    </a>
                }
            </div>
        </div>
    </div>
</div>


<div class="bg-gray-900 rounded-2xl border border-gray-800 p-8 shadow-xl">
    <h3 class="font-display font-bold text-2xl text-white mb-8 border-b border-gray-800 pb-4">Community Reviews</h3>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <form asp-action="AddComment" method="post" class="mb-10 bg-gray-800/50 p-6 rounded-xl border border-gray-700">
            <input type="hidden" name="bookId" value="@Model.Id" />
            <h4 class="text-white font-medium mb-4">Leave a review</h4>
            <div class="mb-4">
                <textarea name="text" rows="3" class="w-full bg-gray-900 border border-gray-700 text-white rounded-lg focus:ring-brand-red focus:border-brand-red block p-4 transition-colors outline-none resize-none" placeholder="What did you think about this book?"></textarea>
            </div>
            <div class="flex justify-end">
                <button type="submit" class="px-6 py-2 bg-brand-red hover:bg-red-700 text-white font-semibold rounded-lg transition-colors">Post Review</button>
            </div>
        </form>
    }
    else
    {
        <div class="mb-10 p-6 bg-brand-red/10 border border-brand-red/20 rounded-xl flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-brand-red font-medium">Log in to leave a review and rate this book.</p>
            <a href="/Identity/Account/Login" class="px-6 py-2 bg-gray-900 hover:bg-gray-800 border border-gray-700 text-white font-semibold rounded-lg transition-colors whitespace-nowrap">Sign in</a>
        </div>
    }

    <div class="space-y-6">
        @if (!Model.Comments.Any())
        {
            <p class="text-gray-500 italic">No reviews yet. Be the first!</p>
        }
        else
        {
            foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
            {
                <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-800">
                    <div class="flex justify-between items-start mb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-red to-orange-500 flex items-center justify-center text-white font-bold">
                                @(comment.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <div>
                                <span class="block font-medium text-white">@(comment.User?.UserName ?? "Unknown")</span>
                                <span class="block text-xs text-gray-500">@comment.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <p class="text-gray-300">@comment.Text</p>
                </div>
            }
        }
    </div>
</div>
