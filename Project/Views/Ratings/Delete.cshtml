@model RaceReader.Models.Rating
@{
    ViewData["Title"] = "Delete Rating";
}

<div class="mb-8">
    <a asp-action="Index" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors flex items-center gap-2 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Ratings
    </a>
    <h1 class="font-display font-black text-4xl text-white italic tracking-tight uppercase">Delete Rating</h1>
</div>

<div class="bg-gray-900 border border-brand-red/50 rounded-2xl p-8 max-w-2xl shadow-2xl relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-2 bg-brand-red"></div>
    <div class="flex items-center gap-4 mb-6">
        <div class="p-3 bg-brand-red/10 text-brand-red rounded-full">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </div>
        <div>
            <h2 class="text-xl font-bold text-white">Delete this rating?</h2>
            <p class="text-gray-400 text-sm">This action cannot be undone. The rating will be permanently removed.</p>
        </div>
    </div>

    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 mb-8 space-y-4">
        <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1">User</span>
            <span class="text-white font-medium text-sm">@Model.User?.Email</span>
        </div>
        <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1">Book</span>
            <span class="text-gray-300 font-medium text-sm">@Model.Book?.Title</span>
        </div>
        <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1">Score</span>
            <div class="inline-flex gap-1 text-yellow-400">
                @for (int i = 0; i < Model.Score; i++)
                {
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                }
            </div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="flex gap-4">
            <button type="submit" class="px-6 py-2 bg-brand-red hover:bg-red-700 text-white font-semibold rounded-lg transition-all shadow-lg shadow-brand-red/20">
                Yes, Delete Rating
            </button>
            <a asp-action="Index" class="px-6 py-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg transition-colors border border-gray-700">
                Cancel
            </a>
        </div>
    </form>
</div>
