@model IEnumerable<RaceReader.Models.Rating>
@{
    ViewData["Title"] = "Ratings Moderation";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="font-display font-black text-4xl text-white italic tracking-tight uppercase mb-2">Ratings</h1>
        <p class="text-gray-400">Moderate user ratings for books.</p>
    </div>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden shadow-2xl">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-800/50 border-b border-gray-700">
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider">User & Date</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Book</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Score</th>
                    <th class="p-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                @foreach (var item in Model) {
                <tr class="hover:bg-gray-800/30 transition-colors group">
                    <td class="p-4 align-middle">
                        <div class="font-medium text-white text-sm">@item.User?.Email</div>
                        <div class="text-xs text-gray-500 mt-1">@item.CreatedAt.ToString("g")</div>
                    </td>
                    <td class="p-4 align-middle">
                        <div class="text-sm text-gray-300 font-medium">@item.Book?.Title</div>
                    </td>
                    <td class="p-4 align-middle text-center">
                        <div class="inline-flex gap-1 text-yellow-400">
                            @for (int i = 0; i < item.Score; i++)
                            {
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                            }
                            @for (int i = item.Score; i < 5; i++)
                            {
                                <svg class="w-4 h-4 text-gray-700 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                            }
                        </div>
                    </td>
                    <td class="p-4 text-right align-middle">
                        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="p-2 text-red-500 hover:text-white hover:bg-red-600 rounded-lg transition-colors" title="Delete">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
