@model RaceReader.Models.HomeViewModel
@{
    ViewData["Title"] = "Catalog";
}


<div class="relative min-h-[300px] flex items-center justify-center bg-gray-900 overflow-hidden rounded-2xl mb-8 shadow-2xl">
    <div class="absolute inset-0 opacity-40 bg-[url('/images/motorsport_hero_bg.png')] bg-cover bg-center mix-blend-overlay"></div>
    <div class="relative z-10 max-w-2xl p-8 md:p-12 text-center">
        <h1 class="font-display font-black text-3xl md:text-4xl text-white italic tracking-tight mb-2 uppercase">
            Start Your <span class="text-brand-red">Engines.</span>
        </h1>
        <p class="text-base text-gray-400 font-medium">
            Access exclusive motorsport literature, driver biographies, and technical magazines. Pay only for the minutes you read.
        </p>
    </div>
</div>


<form method="get" class="mb-10 bg-gray-900/50 p-6 rounded-2xl border border-gray-800 flex flex-col md:flex-row gap-4 items-end backdrop-blur-md">
    <div class="w-full md:w-1/3">
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Search</label>
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" name="searchQuery" value="@Context.Request.Query["searchQuery"]" placeholder="Title or Author..." class="w-full bg-gray-800 border border-gray-700 text-white text-sm rounded-lg pl-10 p-3 focus:ring-brand-red focus:border-brand-red block transition-colors outline-none">
        </div>
    </div>
    <div class="w-full md:w-1/3">
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Genre</label>
        <select name="categoryId" class="w-full bg-gray-800 border border-gray-700 text-white text-sm rounded-lg focus:ring-brand-red focus:border-brand-red block p-3 transition-colors outline-none">
            <option value="">All Genres</option>
            @foreach (var cat in Model.Categories)
            {
                var isSelected = Context.Request.Query["categoryId"] == cat.Id.ToString() ? "selected" : "";
                <option value="@cat.Id" selected="@(Context.Request.Query["categoryId"] == cat.Id.ToString())">@cat.Name</option>
            }
        </select>
    </div>
    <div class="w-full md:w-auto">
        <button type="submit" class="w-full md:w-auto px-6 py-3 bg-brand-red hover:bg-red-700 text-white font-semibold rounded-lg transition-all shadow-lg shadow-brand-red/20 flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
            Filter
        </button>
    </div>
</form>


@if (!Model.Books.Any())
{
    <div class="text-center py-20 bg-gray-900/30 rounded-2xl border border-gray-800 border-dashed">
        <svg class="mx-auto h-12 w-12 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-300">No books found</h3>
        <p class="mt-1 text-sm text-gray-500">Try adjusting your filters or check back later.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var book in Model.Books)
        {
            <div class="group bg-gray-900 rounded-xl border border-gray-800 overflow-hidden hover:border-brand-red/50 hover:shadow-2xl hover:shadow-brand-red/10 transition-all duration-300 flex flex-col">
                <div class="aspect-[2/3] relative overflow-hidden bg-gray-800">
                    @if (!string.IsNullOrEmpty(book.CoverImagePath))
                    {
                        <img src="@book.CoverImagePath" alt="@book.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center text-gray-600 font-display italic text-2xl uppercase">No Cover</div>
                    }
                    <div class="absolute top-3 left-3 flex flex-col gap-2">
                        <span class="px-2.5 py-1 bg-brand-red/80 backdrop-blur-md text-white text-xs font-bold rounded uppercase tracking-wider">
                            @(Model.Categories.FirstOrDefault(c => c.Id == book.CategoryId)?.Name ?? "N/A")
                        </span>
                        @if (book.Ratings != null && book.Ratings.Any())
                        {
                            var avgRating = Math.Round(book.Ratings.Average(r => r.Score), 1);
                            <div class="px-2.5 py-1 bg-gray-900/80 backdrop-blur-md text-brand-red text-xs font-bold rounded flex items-center gap-1">
                                <span>@avgRating</span>
                                <svg class="w-3 h-3 text-brand-red" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                            </div>
                        }
                    </div>
                </div>
                <div class="p-5 flex flex-col flex-grow">
                    <h3 class="font-display font-bold text-xl text-white mb-1 line-clamp-1">@book.Title</h3>
                    <p class="text-sm text-gray-400 mb-4">@book.Author</p>
                    <div class="mt-auto">
                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.Id" class="block w-full py-2.5 text-center bg-gray-800 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg transition-colors border border-gray-700 hover:border-gray-600">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
