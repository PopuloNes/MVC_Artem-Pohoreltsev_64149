@{
    ViewData["Title"] = "Pricing";
}

<div class="text-center mb-16">
    <h1 class="font-display font-black text-4xl md:text-5xl text-white italic tracking-tight mb-4 uppercase">
        Fuel Your <span class="text-brand-red">Passion.</span>
    </h1>
    <p class="text-lg text-gray-400 font-medium max-w-2xl mx-auto">
        Buy tokens and spend them per minute of reading. No monthly subscriptions. Just pay as you read.
    </p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
    <div class="bg-gray-900 border border-gray-800 rounded-3xl p-8 shadow-xl flex flex-col hover:border-gray-700 transition-colors">
        <h3 class="text-xl font-bold text-white mb-2">Pit Stop</h3>
        <p class="text-gray-400 text-sm mb-6">Perfect for a quick read during the weekend.</p>
        <div class="mb-8">
            <span class="text-4xl font-black text-white">$5</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>120 Tokens</strong></span>
            </li>
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>2 hours of reading</span>
            </li>
        </ul>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="Payment" asp-action="CreateCheckoutSession" method="post">
                <input type="hidden" name="tokens" value="120" />
                <input type="hidden" name="price" value="500" />
                <input type="hidden" name="packageName" value="Pit Stop" />
                <button type="submit" class="w-full py-3 px-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition-colors border border-gray-700">Select Plan</button>
            </form>
        }
        else
        {
            <a href="/Identity/Account/Login" class="block text-center w-full py-3 px-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition-colors border border-gray-700">Sign in to Buy</a>
        }
    </div>

    <div class="bg-gray-800 border-2 border-brand-red rounded-3xl p-8 shadow-2xl shadow-brand-red/10 flex flex-col relative transform md:-translate-y-4">
        <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
            <span class="bg-brand-red text-white text-xs font-bold uppercase tracking-wider py-1 px-3 rounded-full">Most Popular</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Full Race</h3>
        <p class="text-gray-400 text-sm mb-6">For the dedicated motorsport enthusiast.</p>
        <div class="mb-8">
            <span class="text-4xl font-black text-white">$15</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>400 Tokens</strong></span>
            </li>
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>6.5 hours of reading</span>
            </li>
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Includes 10% bonus tokens</span>
            </li>
        </ul>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="Payment" asp-action="CreateCheckoutSession" method="post">
                <input type="hidden" name="tokens" value="400" />
                <input type="hidden" name="price" value="1500" />
                <input type="hidden" name="packageName" value="Full Race" />
                <button type="submit" class="w-full py-3 px-4 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-red/30">Buy Now</button>
            </form>
        }
        else
        {
            <a href="/Identity/Account/Login" class="block text-center w-full py-3 px-4 bg-brand-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-red/30">Sign in to Buy</a>
        }
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-3xl p-8 shadow-xl flex flex-col hover:border-gray-700 transition-colors">
        <h3 class="text-xl font-bold text-white mb-2">Championship</h3>
        <p class="text-gray-400 text-sm mb-6">Read everything without worrying about time.</p>
        <div class="mb-8">
            <span class="text-4xl font-black text-white">$40</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><strong>1200 Tokens</strong></span>
            </li>
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>20 hours of reading</span>
            </li>
            <li class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-brand-red mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Best value</span>
            </li>
        </ul>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="Payment" asp-action="CreateCheckoutSession" method="post">
                <input type="hidden" name="tokens" value="1200" />
                <input type="hidden" name="price" value="4000" />
                <input type="hidden" name="packageName" value="Championship" />
                <button type="submit" class="w-full py-3 px-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition-colors border border-gray-700">Select Plan</button>
            </form>
        }
        else
        {
            <a href="/Identity/Account/Login" class="block text-center w-full py-3 px-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition-colors border border-gray-700">Sign in to Buy</a>
        }
    </div>
</div>
