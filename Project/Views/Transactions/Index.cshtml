@model IEnumerable<RaceReader.Models.Transaction>

@{
    ViewData["Title"] = "Transactions Admin";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="font-display font-black text-3xl text-white italic uppercase tracking-tight">Transactions</h1>
        <p class="text-gray-400 mt-2">Manage and view all financial transactions.</p>
    </div>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden shadow-2xl">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-300">
            <thead class="text-xs text-gray-400 uppercase bg-gray-800/50">
                <tr>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Date</th>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">User Email</th>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Amount Paid ($)</th>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Tokens Bought</th>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Stripe Session</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                @foreach (var transaction in Model)
                {
                    <tr class="hover:bg-gray-800/30 transition-colors">
                        <td class="px-6 py-4">
                            @transaction.CreatedAt.ToString("g")
                        </td>
                        <td class="px-6 py-4 font-medium text-white">
                            @(transaction.User?.Email ?? "Unknown User")
                        </td>
                        <td class="px-6 py-4">
                            @transaction.Amount.ToString("C")
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 bg-brand-red/20 text-brand-red rounded font-bold">@transaction.TokensAdded Tokens</span>
                        </td>
                        <td class="px-6 py-4">
                            @if (transaction.Status == "Completed")
                            {
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-green-900/50 text-green-400">@transaction.Status</span>
                            }
                            else if (transaction.Status == "Pending")
                            {
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-yellow-900/50 text-yellow-400">@transaction.Status</span>
                            }
                            else
                            {
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-red-900/50 text-red-400">@transaction.Status</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-xs font-mono text-gray-500">
                            @transaction.StripeSessionId
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-gray-500">
                No transactions found.
            </div>
        }
    </div>
</div>
